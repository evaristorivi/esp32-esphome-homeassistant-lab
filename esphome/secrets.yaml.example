# Ejemplo de secrets.yaml para ESPHome
wifi_ssid: "TU_SSID"
wifi_password: "TU_PASSWORD"
ota_password: "TU_OTA_PASSWORD"
api_encryption_key: "TU_API_ENCRYPTION_KEY"
# Solo necesario para cyd_weather*.yaml y cyd_*vwce*.yaml (los que usan sensores de HA):
location_name: home         # prefijo de los sensores HA (sensor.home_temperatura, etc.)
location_display: "Mi Casa" # texto visible en el display ESP32

